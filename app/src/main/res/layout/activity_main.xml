<?xml version="1.0" encoding="utf-8" ?>
<!--
    Single responsive layout for the automotive HUD.

    Responsiveness is achieved entirely within this one file:
      • Right panel width = 25% of screen via constraintWidth_percent="0.25"
      • Panel section heights are proportional via layout_weight (nav 1.2, lane 2, speed 1)
      • sp text sizes are density-independent — consistent physical size on every screen
      • dp padding/margins are density-independent

    No layout-qualifier folders needed.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
>

    <!-- MAP – base layer -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
    />

    <!-- ══════════════════════════════════════════════════════════════
         RIGHT PANEL  –  always 25% of screen width, full height
         Sections fill proportional heights via layout_weight.
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="0dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.25"
    >

        <!-- Navigation info card (weight 1.2) -->
        <FrameLayout
            android:background="@drawable/panel_top_box"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="6dp"
        >

            <!-- START ROUTE button -->
            <LinearLayout
                android:id="@+id/startRouteContainer"
                android:orientation="vertical"
                android:padding="@dimen/card_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:visibility="visible"
            >
                <TextView
                    android:id="@+id/btnStartRoute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/start_route"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="@dimen/text_xlarge"
                    android:textStyle="bold"
                    android:fontFamily="DM Mono"
                    android:clickable="true"
                    android:focusable="true"
                />
            </LinearLayout>

            <!-- NAV INFO (shown during navigation) -->
            <LinearLayout
                android:id="@+id/navInfoContainer"
                android:orientation="horizontal"
                android:padding="@dimen/card_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:visibility="gone"
            >
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                >
                    <TextView
                        android:id="@+id/txtNavArrival"
                        android:text="--:--"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="@dimen/text_xxlarge"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    />
                    <TextView
                        android:text="@string/arrival"
                        android:textColor="?attr/colorTextHint"
                        android:textSize="@dimen/text_regular"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="50dp"
                    android:background="?attr/colorDividerLight"
                    android:layout_marginHorizontal="12dp"
                />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                >
                    <TextView
                        android:id="@+id/txtNavDistance"
                        android:text="--"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="@dimen/text_large"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    />
                    <TextView
                        android:text="@string/distance_unit"
                        android:textColor="?attr/colorTextHint"
                        android:textSize="@dimen/text_regular"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

        <!-- Stop-navigation button -->
        <FrameLayout
            android:id="@+id/stopNavContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
        >
            <ImageView
                android:id="@+id/btnStopNavigation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                android:background="@drawable/stop_navigation_button_bg"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="?attr/colorIconDefault"
                android:clickable="true"
                android:focusable="true"
            />
        </FrameLayout>

        <!-- Lane preview / TopDownCarView (weight 2) -->
        <FrameLayout
            android:background="@drawable/panel_lane_box"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="2"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="6dp"
        >
            <com.example.myapplication.TopDownCarView
                android:id="@+id/topDownCarView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
            />
            <ImageView
                android:id="@+id/overtakingWarningIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:src="@drawable/red_warning"
                android:visibility="gone"
                android:contentDescription="Overtaking warning"
            />
        </FrameLayout>

        <!-- Speed area (weight 1) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:clipChildren="false"
            android:clipToPadding="false"
        >
            <View
                android:id="@+id/speedAlertBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSpeedAlertBackground"
                android:alpha="0"
                android:visibility="gone"
            />

            <LinearLayout
                android:id="@+id/speedArea"
                android:orientation="horizontal"
                android:background="@drawable/panel_bottom_speed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
            >
                <FrameLayout
                    android:id="@+id/speedLimitContainer"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                >
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/speed_limit_circle_bg"
                    />
                    <TextView
                        android:id="@+id/txtSpeedLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="--"
                        android:textColor="?attr/colorTextOnLight"
                        android:textSize="@dimen/text_xlarge"
                        android:textStyle="bold"
                    />
                </FrameLayout>

                <ImageView
                    android:id="@+id/speedAlertIcon"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="0dp"
                />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:paddingEnd="8dp"
                >
                    <TextView
                        android:id="@+id/txtCurrentSpeed"
                        android:text="0"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="@dimen/text_large"
                        android:fontFamily="DM Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    />
                    <TextView
                        android:id="@+id/txtSpeedUnit"
                        android:text="@string/speed_unit"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="@dimen/text_large"
                        android:fontFamily="DM Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                    />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- WEATHER BADGE – top-left overlay -->
    <LinearLayout
        android:id="@+id/weatherBadge"
        android:orientation="horizontal"
        android:background="@drawable/weather_bg"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
    >
        <TextView
            android:id="@+id/txtWeatherEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌡️"
            android:textSize="@dimen/text_xlarge"
        />
        <TextView
            android:id="@+id/txtTemperature"
            android:text="11°C"
            android:textColor="?attr/colorTextPrimary"
            android:textStyle="bold"
            android:textSize="@dimen/text_xlarge"
            android:fontFamily="DM Mono"
            android:layout_marginStart="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
        />
        <LinearLayout
            android:id="@+id/weatherCardExtras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
        />
    </LinearLayout>

    <!-- NAVIGATION INSTRUCTION BANNER – right of weather badge -->
    <LinearLayout
        android:id="@+id/navigationBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_shadow"
        android:paddingHorizontal="20dp"
        android:paddingVertical="@dimen/card_corner_radius"
        android:layout_marginStart="12dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/weatherBadge"
        app:layout_constraintBottom_toBottomOf="@id/weatherBadge"
        app:layout_constraintStart_toEndOf="@id/weatherBadge"
    >
        <ImageView
            android:id="@+id/imgManeuverIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_straight"
            android:scaleType="fitCenter"
            app:tint="?attr/colorIconDefault"
        />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/card_corner_radius"
        >
            <TextView
                android:id="@+id/txtNextManeuverDistance"
                android:text="800 m"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            />
            <TextView
                android:id="@+id/txtManeuverInstruction"
                android:text="@string/turn_right"
                android:textColor="?attr/colorTextTertiary"
                android:textSize="@dimen/text_medium_small"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            />
        </LinearLayout>
    </LinearLayout>

    <!-- SETTINGS BADGE – bottom-left overlay -->
    <LinearLayout
        android:id="@+id/btnSettings"
        android:orientation="horizontal"
        android:background="@drawable/weather_bg"
        android:padding="12dp"
        android:layout_margin="3dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
    >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="@dimen/text_xlarge"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="@dimen/text_xlarge"
            android:fontFamily="DM Mono"
            android:layout_marginStart="12dp"
        />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
