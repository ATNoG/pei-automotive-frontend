<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceOverlay"
    android:clickable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/settingsCard"
        android:layout_width="480dp"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:elevation="8dp"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="?attr/colorSurfaceDialog">

            <!-- Fixed Header (matches weather dialog header style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:background="?attr/colorSurfaceDialogHeader">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorTextPrimary" />

                <ImageButton
                    android:id="@+id/btnCloseSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="?attr/colorIconDefault"
                    android:contentDescription="@string/settings_close" />

            </LinearLayout>

            <!-- Scrollable Content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- User Account Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/card_background_with_stroke">

                        <!-- User Info -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:id="@+id/fullNameTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unknown_user"
                                android:textColor="?attr/colorTextPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/usernameTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="?attr/colorTextSecondary"
                                android:textSize="14sp"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Logout Button -->
                        <Button
                            android:id="@+id/btnLogout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/button_logout_background"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:text="@string/logout"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:minHeight="48dp" />

                    </LinearLayout>

                    <!-- Map Style Section Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/map_style"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:layout_marginBottom="12dp" />

                    <!-- Dark / Light Mode Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/card_background_with_stroke"
                        android:layout_marginBottom="20dp">

                        <!-- Label (left, takes available space) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/theme_mode"
                            android:textSize="14sp"
                            android:textColor="?attr/colorTextPrimary" />

                        <!-- 🌙 dark emoji -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌙"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchLightMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />

                        <!-- ☀️ light emoji -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️"
                            android:textSize="18sp"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Language Section Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:layout_marginBottom="12dp"
                        android:layout_marginTop="20dp" />

                    <!-- Language Selection Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/card_background_with_stroke"
                        android:layout_marginBottom="20dp">

                        <Button
                            android:id="@+id/btnEnglish"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="English"
                            android:textSize="14sp"
                            android:textColor="?attr/colorTextPrimary"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnPortuguese"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Português"
                            android:textSize="14sp"
                            android:textColor="?attr/colorTextPrimary"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>
                  
                    <!-- Accessibility Section Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/accessibility"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:layout_marginBottom="12dp" />

                    <!-- Colorblind Mode Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/card_background_with_stroke"
                        android:layout_marginBottom="20dp">
                         
                        <TextView
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:text="@string/colorblind"
                          android:textSize="14sp"
                          android:textColor="?attr/colorTextPrimary" />

                        <androidx.appcompat.widget.SwitchCompat
                          android:id="@+id/switchColorBlind"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:checked="false" />

                    </LinearLayout>

                    <!-- Alerts Section Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/alerts"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:layout_marginBottom="12dp" />

                    <!-- Alert Grid Container (populated programmatically as 2-column grid) -->
                    <LinearLayout
                        android:id="@+id/alertSettingsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
