<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/settingsCard"
        android:layout_width="480dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:elevation="8dp"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D2D2D"
            android:maxHeight="600dp">

            <!-- Fixed Header (matches weather dialog header style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:background="#252525">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <ImageButton
                    android:id="@+id/btnCloseSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="#FFFFFF"
                    android:contentDescription="@string/settings_close" />

            </LinearLayout>

            <!-- Scrollable Content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Map Style Section Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/map_style"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <!-- Dark / Light Mode Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/card_background_with_stroke"
                        android:layout_marginBottom="20dp">

                        <!-- Label (left, takes available space) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/theme_mode"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                        <!-- 🌙 dark emoji -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌙"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchLightMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />

                        <!-- ☀️ light emoji -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️"
                            android:textSize="18sp"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Language Section Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp"
                        android:layout_marginTop="20dp" />

                    <!-- Language Selection Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/card_background_with_stroke"
                        android:layout_marginBottom="20dp">

                        <Button
                            android:id="@+id/btnEnglish"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="English"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnPortuguese"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Português"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Alerts Section Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/alerts"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <!-- Alert Grid Container (populated programmatically as 2-column grid) -->
                    <LinearLayout
                        android:id="@+id/alertSettingsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
