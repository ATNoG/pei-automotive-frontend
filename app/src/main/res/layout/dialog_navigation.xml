<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/destinationOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceOverlay"
    android:clickable="true"
    android:focusable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/dialogCard"
        android:layout_width="450dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="?attr/colorSurfaceDialogCard"
        app:cardCornerRadius="@dimen/dialog_margin"
        app:cardElevation="@dimen/card_corner_radius">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

            <!-- Header -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dialog_margin">
                
                <ImageView
                    android:src="@drawable/ic_navigation"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="14dp"
                    app:tint="?attr/colorAccentBlue" />
                
                <TextView
                    android:text="@string/alert_navigation"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
                
                <ImageButton
                    android:id="@+id/btnClose"
                    android:src="@drawable/ic_close"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="8dp"
                    app:tint="?attr/colorIconMuted" />
            </LinearLayout>

            <!-- Search Input -->
            <EditText
                android:id="@+id/edtSearchDestination"
                android:hint="@string/search_destination"
                android:inputType="text|textNoSuggestions"
                android:textColor="?attr/colorTextPrimary"
                android:textColorHint="?attr/colorTextTertiary"
                android:textSize="@dimen/text_regular"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="@dimen/card_corner_radius"
                android:background="?attr/colorSurfaceButtonNeutral"
                android:maxLines="1"
                android:imeOptions="flagNoExtractUi|actionDone"
                android:importantForAutofill="no" />

            <!-- Search Results Container -->
            <FrameLayout
                android:id="@+id/searchResultsContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"  
                android:layout_weight="1"    
                android:visibility="gone">

                <!-- Results RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSearchResults"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurfaceButtonNeutral" />

                <!-- Empty State / Loading -->
                <TextView
                    android:id="@+id/txtSearchEmpty"
                    android:text="@string/no_results"
                    android:textColor="?attr/colorTextTertiary"
                    android:textSize="@dimen/text_regular"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Route Info Preview (shown after selection) -->
            <LinearLayout
                android:id="@+id/routeInfoPreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"  
                android:layout_weight="1"    
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    
                    <TextView
                        android:id="@+id/txtRouteDestination"
                        android:text="Mercado Santiago"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="@dimen/text_medium_small"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    
                    <TextView
                        android:id="@+id/txtRouteInfo"
                        android:text="@string/calculating_route"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="@dimen/text_small"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnCancel"
                    android:text="@string/cancel"
                    android:textSize="@dimen/text_regular"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="?attr/colorSurfaceButtonNeutral" />

                <Button
                    android:id="@+id/btnStartNavigation"
                    android:text="@string/start_navigation"
                    android:textSize="@dimen/text_regular"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorTextPrimary"
                    android:enabled="false"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.5"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="?attr/colorStatusSuccess" />

            </LinearLayout>

        </LinearLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>

</FrameLayout>
